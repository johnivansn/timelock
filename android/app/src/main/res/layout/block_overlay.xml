<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#F2000000" android:clickable="true" android:focusable="true">

  <!-- Fondo con gradiente oscuro -->
  <View android:layout_width="match_parent" android:layout_height="match_parent" android:background="#CC1a1a1a" />

  <!-- Contenedor central -->
  <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical" android:padding="24dp">

    <!-- Icono de candado con animación -->
    <FrameLayout android:layout_width="140dp" android:layout_height="140dp" android:layout_marginBottom="32dp" android:background="@drawable/circle_background" android:gravity="center">

      <ImageView android:layout_width="70dp" android:layout_height="70dp" android:layout_gravity="center" android:src="@android:drawable/ic_lock_idle_lock" android:tint="#FF6B6B" />
    </FrameLayout>

    <!-- Título principal -->
    <TextView android:id="@+id/block_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="16dp" android:gravity="center" android:text="🚫 Aplicación Bloqueada" android:textColor="#FFFFFF" android:textSize="28sp" android:textStyle="bold" />

    <!-- Razón del bloqueo -->
    <TextView android:id="@+id/block_reason" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" android:gravity="center" android:text="Razón: Cuota agotada" android:textColor="#FFCA28" android:textSize="14sp" android:textStyle="bold" />

    <!-- Mensaje de bloqueo -->
    <TextView android:id="@+id/block_message" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="24dp" android:gravity="center" android:text="Has alcanzado el límite de tiempo permitido para esta app" android:textColor="#E8E8E8" android:textSize="16sp" android:lineSpacingExtra="4dp" />

    <!-- Contador de tiempo -->
    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="32dp" android:orientation="horizontal" android:padding="12dp">

      <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⏱️ " android:textSize="20sp" />

      <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="Regresando a inicio en..." android:textColor="#FFCA28" android:textSize="14sp" android:textStyle="bold" />
    </LinearLayout>

    <!-- Línea decorativa -->
    <View android:layout_width="60dp" android:layout_height="3dp" android:layout_marginBottom="24dp" android:background="#FF6B6B" />

    <!-- Información adicional -->
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:text="Intenta de nuevo mañana o ajusta tu límite de tiempo" android:textColor="#BDBDBD" android:textSize="13sp" android:lineSpacingExtra="2dp" />

    <!-- Espaciador -->
    <Space android:layout_width="wrap_content" android:layout_height="40dp" />

    <!-- Indicador visual de progreso -->
    <ProgressBar android:layout_width="200dp" android:layout_height="wrap_content" android:layout_gravity="center" android:indeterminate="true" android:indeterminateTint="#FF6B6B" />

  </LinearLayout>

</FrameLayout>